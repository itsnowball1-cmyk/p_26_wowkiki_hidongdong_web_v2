# NAS 배포 환경변수. 실제 값은 .env 로 복사 후 채워서 사용.
# .env 는 git 에 커밋되지 않음.

# DB root 비밀번호 (16자 이상 권장)
DB_PASSWORD=change-me-strong-password

# DB 이름
DB_DATABASE=wowkiki

# 미디어/녹음 파일 베이스 URL (있다면)
FILES_BASE_URL=

# 알리고 SMS API (https://www.aligo.in → 문자 서비스 → API 연동 정보)
# ⚠️  Cloudflare 마이그레이션 시 주의:
#     Cloudflare Workers는 외부 HTTP 요청이 가능하므로 알리고 API 자체는 그대로 쓸 수 있으나,
#     환경변수를 wrangler secret 또는 Workers 대시보드 → Settings → Variables 에 등록해야 함.
#     (wrangler secret put ALIGO_KEY / ALIGO_USER_ID / ALIGO_SENDER)
#     NAS .env 파일이 아니라 Cloudflare 쪽에 별도 설정 필요.
ALIGO_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=
