# syntax=docker/dockerfile:1.7
# Build stage — vite build
FROM node:20-slim AS build
WORKDIR /app
COPY code/package.json code/package-lock.json ./
RUN npm ci
COPY code/tsconfig.json code/tsconfig.app.json code/tsconfig.node.json code/tsconfig.server.json ./
COPY code/vite.config.ts code/postcss.config.js code/tailwind.config.js code/index.html ./
COPY code/public ./public
COPY code/src ./src
COPY code/server ./server
RUN npm run build

# Runtime — nginx serving SPA + /api proxy
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
